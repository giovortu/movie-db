[Unit]
Description=Movie DB Backend e Frontend
After=network.target

[Service]
Type=oneshot
RemainAfterExit=yes
User=giovortu
WorkingDirectory=/home/giovortu/bin/movie-db
ExecStart= /usr/bin/bash /home/giovortu/bin/movie-db/manage-movie-db.sh start
ExecStop=  /usr/bin/bash /home/giovortu/bin/movie-db/manage-movie-db.sh stop
Restart=on-failure

[Install]
WantedBy=multi-user.target
